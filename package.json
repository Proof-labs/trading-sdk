{
  "name": "@proof/trading-sdk",
  "version": "1.1.0",
  "description": "TypeScript SDK for Proof Exchange — signing, encoding, querying, and submitting actions.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Proof-labs/trading-sdk.git"
  },
  "homepage": "https://github.com/Proof-labs/trading-sdk#readme",
  "bugs": {
    "url": "https://github.com/Proof-labs/trading-sdk/issues"
  },
  "keywords": [
    "proof",
    "exchange",
    "trading",
    "sdk",
    "ed25519",
    "messagepack"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "example": "npx tsx examples/connect-and-trade.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta.3",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
