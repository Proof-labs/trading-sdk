{
  "name": "@proof/trading-sdk",
  "version": "2.0.0",
  "description": "TypeScript SDK for Proof Exchange — signing, encoding, querying, and submitting actions.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Proof-labs/trading-sdk.git"
  },
  "homepage": "https://github.com/Proof-labs/trading-sdk#readme",
  "bugs": {
    "url": "https://github.com/Proof-labs/trading-sdk/issues"
  },
  "keywords": [
    "proof",
    "exchange",
    "trading",
    "sdk",
    "ed25519",
    "messagepack"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:wasm && tsc && npm run copy:wasm",
    "build:wasm": "cargo build -p proof-trading-sdk-wasm --target wasm32-unknown-unknown --release && wasm-bindgen --target web --out-dir src/wasm target/wasm32-unknown-unknown/release/proof_trading_sdk_wasm.wasm",
    "copy:wasm": "node -e \"require('node:fs').cpSync('src/wasm','dist/wasm',{recursive:true})\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build:wasm",
    "test": "vitest run",
    "smoke:browser:prepare": "node scripts/prepare-browser-smoke.mjs .browser-smoke",
    "smoke:browser": "node scripts/browser-smoke.mjs .browser-smoke",
    "example": "npx tsx examples/connect-and-trade.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta.3",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "playwright": "1.61.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.0",
    "vite": "8.1.5",
    "vitest": "^4.1.0"
  }
}
